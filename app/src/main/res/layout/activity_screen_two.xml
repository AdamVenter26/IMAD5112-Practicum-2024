<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ScreenTwo">

    <TextView
        android:id="@+id/txtHeading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter Screen Time"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/edtMorning1"
        android:layout_width="407dp"
        android:layout_height="56dp"
        android:layout_marginTop="20dp"
        android:hint="Monday Morning"
        android:inputType="number"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtHeading" />

    <EditText
        android:id="@+id/edtAfternoon1"
        android:layout_width="408dp"
        android:layout_height="53dp"
        android:layout_marginTop="10dp"
        android:hint="Monday Afternoon"
        android:inputType="number"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/edtMorning1" />

    <EditText
        android:id="@+id/edtMorning2"
        android:layout_width="400dp"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:hint="Tuesday Morning"
        android:inputType="number"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/edtAfternoon1" />

    <EditText
        android:id="@+id/edtAfternoon2"
        android:layout_width="407dp"
        android:layout_height="55dp"
        android:layout_marginTop="10dp"
        android:hint="Tuesday Afternoon"
        android:inputType="number"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/edtMorning2" />

    <Button
        android:id="@+id/btnDetailed"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="View Report"
        app:layout_constraintTop_toBottomOf="@id/edtAfternoon2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>

    <Button
        android:id="@+id/btnClear"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Clear"
        app:layout_constraintTop_toBottomOf="@id/btnDetailed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>